{
    "name": "skiexx/laravel-data-scramble",
    "description": "Free Scramble extension for automatic OpenAPI schema generation from spatie/laravel-data classes",
    "keywords": ["laravel", "openapi", "scramble", "laravel-data", "spatie", "swagger"],
    "homepage": "https://github.com/skiexx/laravel-data-scramble",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "skiexx",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0",
        "dedoc/scramble": "^0.13",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Skiexx\\LaravelDataScramble\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Skiexx\\LaravelDataScramble\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Skiexx\\LaravelDataScramble\\LaravelDataScrambleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
